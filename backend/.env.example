# ==============================================================================
# DAOM Platform Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values
# See docs/DEPLOYMENT_GUIDE.md for detailed setup instructions
# ==============================================================================

# ===================
# General Settings
# ===================
PROJECT_NAME=DAOM

# CORS Origins - JSON array of allowed frontend URLs
# Example: ["https://daom-frontend.azurecontainerapps.io", "http://localhost:5173"]
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# ===================
# Azure Cosmos DB
# ===================
# Get from Azure Portal -> Cosmos DB -> Keys
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=daom

# ===================
# Azure AI Document Intelligence (OCR)
# ===================
# Get from Azure Portal -> Document Intelligence -> Keys and Endpoint
AZURE_FORM_ENDPOINT=https://your-docintel.cognitiveservices.azure.com/
AZURE_FORM_KEY=your-document-intelligence-key

# ===================
# Azure OpenAI (LLM)
# ===================
# Get from Azure Portal -> Azure OpenAI -> Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key

# Deployment name as shown in Azure OpenAI Studio
# Examples: gpt-4o, gpt-4o-mini, gpt-4.1
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# API version - use latest stable version
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ===================
# Azure Blob Storage
# ===================
# Get from Azure Portal -> Storage Account -> Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=documents

# ===================
# Optional: Azure AI Foundry Project
# ===================
# If using Azure AI Foundry instead of Azure OpenAI directly
# AZURE_AIPROJECT_ENDPOINT=https://your-project.openai.azure.com/openai/v1/
# AZURE_AIPROJECT_RESOURCE_ID=/subscriptions/.../projects/...

# ===================
# Optional: Entra ID Authentication
# ===================
# For single sign-on with Microsoft Entra ID
# AZURE_CLIENT_ID=your-app-registration-client-id
# AZURE_TENANT_ID=your-tenant-id
